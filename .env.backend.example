# Production database credentials
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# API connection string (Npgsql format)
POSTGRES_CONNECTION_STRING=Host=db;Database=logger;Username=CHANGE_ME;Password=CHANGE_ME

# Python bot connection string (libpq format)
CONNECTION_STRING=host=db port=5432 dbname=logger user=CHANGE_ME password=CHANGE_ME

# Telegram bot token (from BotFather)
TOKEN=CHANGE_ME

# Shared secret between API and Web containers
APIKEY=CHANGE_ME
